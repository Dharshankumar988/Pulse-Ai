APP_NAME=Pulse API
APP_ENV=production
DEBUG=false
CORS_ORIGINS=*

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-secret-key
SUPABASE_STORAGE_BUCKET=medical-records

MODELS_DIRECTORY=./models
YOLO_FRACTURE_MODEL_PATH=./models/fracture_model.pt
YOLO_TUMOR_MODEL_PATH=./models/brain_model.pt
YOLO_KIDNEY_STONE_MODEL_PATH=./models/kidney_model.pt
EFFICIENTNET_MODEL_PATH=./models/skin_model.pt
MOBILENET_MODEL_PATH=
EFFICIENTNET_LABELS_PATH=
MOBILENET_LABELS_PATH=
ML_DEFAULT_CONFIDENCE=0.25
ML_DEFAULT_TOP_K=3
ML_LOW_CONFIDENCE_THRESHOLD=0.7

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_CACHE_TTL_SECONDS=600

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24